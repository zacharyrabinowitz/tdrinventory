# Flask Configuration
FLASK_ENV=production
FLASK_APP=app.py

# Security - CHANGE THESE IN PRODUCTION!
SECRET_KEY=your-secret-key-here-change-this-to-a-long-random-string-at-least-32-characters
BREAK_GLASS_ADMIN_USERNAME=admin
BREAK_GLASS_ADMIN_PASSWORD=your-secure-break-glass-password-here

# Database
SQLALCHEMY_DATABASE_URI=sqlite:///draftroom_inventory.db

# Session Configuration
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=Lax

# Optional: External Services
# Add any third-party API keys here
